  "share_target": {
    "action": "/share-target.html",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "name",
      "text": "description",
      "url": "link",
      "files": [
        {
          "name": "files",
          "accept": ["image/*"]
        }
      ]
    }
